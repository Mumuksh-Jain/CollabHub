{
  "version": 2,
  "builds": [
    { "src": "package.json", "use": "@vercel/static-build" }
  ],
  "routes": [
    { "src": "/(.*).(js|css|map|png|jpg|svg|ico|woff2?)$", "headers": { "cache-control": "public,max-age=31536000,immutable" }, "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}